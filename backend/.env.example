PORT=5000
MONGODB_URI=mongodb://localhost:27017/onetimesecret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# IMPORTANT: For QR code scanning from mobile devices, set this to your network IP WITH PORT
# Find your IP by running: ipconfig (Windows) or ifconfig (Mac/Linux)
# Example: BASE_URL=http://192.168.1.5:5173
BASE_URL=http://192.168.0.108:5173

# Alternative: FRONTEND_URL (for backward compatibility)
FRONTEND_URL=http://192.168.0.108:5173

# Or use ngrok for public access:
# BASE_URL=https://abcd1234.ngrok.io

# Additional allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=
